{
  "manifest_version": 3,
  "name": "FocusOrb",
  "version": "1.0.0",
  "description": "Just a minimal floating Pomodoro timer",
  "permissions": ["storage", "notifications", "windows", "system.display"],
  "action": {
    "default_title": "FocusOrb",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
